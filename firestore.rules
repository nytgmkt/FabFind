rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId} {
      allow read, write: if true;
      match /vendors/{vendorId} {
        allow read, write: if true;
      }
    }
    match /vendors/{vendorId} {
      allow read, write: if true;
    }
    match /channels/{channelId} {
      allow read, write: if true;
      match /vendors/{vendorId} {
        allow read, write: if true;
      }
    }
    match /templates/{templateId} {
      allow read, write: if true;
    }
  }
}
